<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="CrossBrowserSuite" parallel="tests" thread-count="3">
<groups>
<run>
<include name="errorHandling"></include>
</run>
</groups>
<listeners>
<listener class-name="Projet_K.testcomponents.Listeners"></listener>
</listeners>
  <test name="ChromeTest">
   <parameter name="BrowerName" value="chrome"/>
    <classes>
      <class name="Project_K.test.ErrorValidations"/>
    </classes>
  </test> <!-- Test -->
  
   <test name="EdgeTest">
   <parameter name="BrowerName" value="edge"/>
    <classes>
      <class name="Project_K.test.ErrorValidations"/>
    </classes>
  </test> <!-- Test -->
     <test name="FirefoxTest">
   <parameter name="BrowerName" value="firefox"/>
    <classes>
      <class name="Project_K.test.ErrorValidations"/>
    </classes>
  </test> <!-- Test -->
</suite> <!-- Suite -->
